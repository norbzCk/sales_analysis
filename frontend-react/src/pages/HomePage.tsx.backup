type AssistantMessage = {
  id: string;
  role: "assistant" | "user";
  text: string;
};

type ProductSearchResponse = {
  items: Product[];
  total: number;
  categories?: string[];
};

function formatMoney(value?: number) {
  return `TZS ${Number(value || 0).toLocaleString(undefined, { maximumFractionDigits: 2 })}`;
}

function resolveImageUrl(url?: string | null) {
  const raw = String(url || "").trim();
  if (!raw) return FALLBACK_IMAGE;
  if (/^https?:\/\//i.test(raw)) return raw;
  if (raw.startsWith("/")) return `${env.apiBase}${raw}`;
  return `${env.apiBase}/${raw.replace(/^\/+/, "")}`;
}

function buildAssistantReply(prompt: string, products: Product[]) {
  const query = prompt.trim().toLowerCase();
    // Business information queries
  if (query.includes("business") || query.includes("company") || query.includes("about") || query.includes("what") && (query.includes("sokolink") || query.includes("platform") || query.includes("marketplace"))) {
    return "SokoLink is a B2B marketplace connecting buyers with trusted sellers across Tanzania. We specialize in systematic sourcing with AI-assisted discovery, verified seller badges, and transparent fulfillment tracking. Our platform helps businesses find reliable products, compare pricing, and coordinate faster deliveries. We serve various categories including electronics, groceries, textiles, and more.";
  }

  // How it works queries
  if (query.includes("how") && (query.includes("work") || query.includes("use") || query.includes("start"))) {
    return "Getting started is easy! Browse our catalog of verified products, use AI mode to describe what you need, or submit an RFQ if you can't find exactly what you're looking for. Sellers will respond with recommendations or quotes. You can compare prices, check seller ratings, and track fulfillment from order to delivery.";
  }

  // Seller/verification queries
  if (query.includes("seller") || query.includes("verified") || query.includes("trust") || query.includes("badge")) {
    return "We verify our sellers through a rigorous process including business documentation, performance tracking, and customer feedback. Look for seller badges like 'Top Rated' or 'Verified Supplier' on product listings. All sellers go through background checks and maintain performance standards.";
  }

  // AI/discovery queries
  if (query.includes("ai") || query.includes("assistant") || query.includes("recommend")) {
    return "Our AI assistant helps you discover products by query.match(/(\d+(?:\.\d+)?)\s*(?:tsh|tzs|shillings?)|i) || query.match(/(?:budget|under|below)\s*(\d+(?:\.\d+)?)|i);standing your needs in natural language. Just describe what you're looking for - whether it's a specific product, budget range, or type of seller. I can suggest trending items, help you compare options, and guide you to the right products for your business.";
  }

  // Delivery/logistics queries
  if (query.includes("delivery") || query.includes("shipping") || query.includes("logistics") || query.includes("track")) {
    return "We provide transparent fulfillment tracking from order to delivery. Sellers coordinate with logistics partners to ensure reliable delivery. You can track your orders in real-time and see last-mile operations. We also offer routing optimization for bulk orders and grouped deliveries.";
  }

  // Pricing/budget queries
  if (query.includes("price") || query.includes("budget") || query.includes("cost") || query.includes("cheap") || query.includes("expensive")) {
    return "Our marketplace offers competitive pricing from verified sellers. Prices vary by product category, quantity, and seller location. Use our search filters to find products within your budget, or submit an RFQ to get customized quotes from multiple sellers.";
  }

  if (!query) {
    return "Tell me the product, budget, or category you want and I’ll suggest a shopping direction.";
  }

  // Product search - check for specific keywords
  const productKeywords = ["electronics", "grocery", "food", "textile", "clothing", "furniture", "equipment", "tools", "supplies", "materials"];
  const matchedCategory = productKeywords.find(keyword => query.includes(keyword));

  if (matchedCategory) {
    const categoryProducts = products.filter(p =>
      (p.category || "").toLowerCase().includes(matchedCategory) ||
      (p.name || "").toLowerCase().includes(matchedCategory) ||
      (p.description || "").toLowerCase().includes(matchedCategory)
    );

    if (categoryProducts.length > 0) {
      const topProducts = categoryProducts.slice(0, 3).map(p => `${p.name} (${formatMoney(p.price)})`).join(", ");
      return `I found ${categoryProducts.length} products in the ${matchedCategory} category. Here are some top options: ${topProducts}. You can browse the full catalog or refine your search for more specific items.`;
    }
  }

  // Generic product search with better matching
  const matches = products.filter((item) => {
    const searchText = `${item.name || ""} ${item.category || ""} ${item.description || ""}`.toLowerCase();
    const words = query.split(" ");
    return words.some(word => word.length > 2 && searchText.includes(word)),
  );
  if (matches.length > 0) {
    const topMatches = matches.slice(0, 3);
    const productList = topMatches.map(p => `${p.name} (${formatMoney(p.price)} - ${p.category || 'General'})`).join(", ");
    return `I found some products that match your description: ${productList}. You can view these in our catalog or let me know if you need more specific recommendations.`;
  }

  // Budget-specific queries
  const budgetMatch = query.match(/(\d+(?:\.\d+)?)\s*(?:tsh|query.match(/(\d+(?:\.\d+)?)\s*(?:tsh|tzs|shillings?)|i) || query.match(/(?:budget|under|below)\s*(\d+(?:\.\d+)?)|i);|query.match(/(\d+(?:\.\d+)?)\s*(?:tsh|tzs|shillings?)|i) || query.match(/(?:budget|under|below)\s*(\d+(?:\.\d+)?)|i);|query.match(/(\d+(?:\.\d+)?)\s*(?:tsh|tzs|shillings?)|i) || query.match(/(?:budget|under|below)\s*(\d+(?:\.\d+)?)|i);|| query.match(/(?:budget|query.match(/(\d+(?:\.\d+)?)\s*(?:tsh|tzs|shillings?)|i) || query.match(/(?:budget|under|below)\s*(\d+(?:\.\d+)?)|i);|below)\s*(\d+(?:\.\d+)?)|query.match(/(\d+(?:\.\d+)?)\s*(?:tsh|tzs|shillings?)|i) || query.match(/(?:budget|under|below)\s*(\d+(?:\.\d+)?)|i);
  if (budgetMatch) {
    const budget = parseFloat(budgetMatch[1]);
    const affordableProducts = products.filter(p => (p.price || 0) <= budget).slice(0, 5);

    if (affordableProducts.length > 0) {
      return `Within your budget of ${formatMoney(budget)}, I found ${affordableProducts.length} products. Here are some options: ${affordableProducts.map(p => `${p.name} (${formatMoney(p.price)})`).join(", ")}.`;
    } else {
      return `I couldn't find products within your budget of ${formatMoney(budget)}. You might want to submit an RFQ to get customized quotes from sellers who can work within your price range.`;
    }
  }

  // No matches found - helpful fallback
  return "I don't have specific information about that yet, but I can help you find products, compare sellers, or submit a request for recommendations. Try describing what you're looking for - a product type, budget range, or specific requirements - and I'll guide you to the right options on our marketplace.";
    }
  }

